<!DOCTYPE html>
<html>
  <head>
    <title>
      Shitcoin Swap
    </title>
    
    <meta name="description" content="Earn Bitcoin and other cryptos on the world's largest open-source MLM platform.">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">

    <script>
      window.ENV = "<%= Rails.env %>";
    </script>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/logo_transparent.png" type="image/png">
    <link rel="apple-touch-icon" href="/logo_black.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= vite_client_tag %>
    <%= vite_javascript_tag 'application' %>
    <%= inertia_ssr_head %>
    <%= Sentry.get_trace_propagation_meta.html_safe %>
  </head>

  <body>
    <%= yield %>
  </body>
</html>
